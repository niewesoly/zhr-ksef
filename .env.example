# ============================================================================
# zhr-ksef — copy to .env and fill in real values. Never commit .env.
#   cp .env.example .env
# ============================================================================

# --- App --------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database (Postgres) ----------------------------------------------------
# POSTGRES_* are consumed by docker-compose.yml when bringing up the DB.
# DATABASE_URL is consumed by the app and drizzle-kit at runtime.
# Host is `localhost` because the app runs on the host in dev; switch to
# `postgres` (service name) once the app is containerised.
POSTGRES_DB=ksef
POSTGRES_USER=ksef
POSTGRES_PASSWORD=ksef
POSTGRES_PORT=5432
DATABASE_URL=postgres://ksef:ksef@localhost:5432/ksef

# --- Redis (BullMQ) ---------------------------------------------------------
# Redis runs with AUTH enabled — REDIS_PASSWORD must be set (compose fails
# fast otherwise). Use the `default` user in the URL; Redis 7 requires it.
REDIS_PASSWORD=ksef
REDIS_PORT=6379
REDIS_URL=redis://default:ksef@localhost:6379

# --- Encryption (envelope encryption KEK) -----------------------------------
# 32 raw bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this key requires re-encrypting every tenant DEK — do not change
# casually. Never reuse across environments.
ENCRYPTION_KEY=

# --- Admin API key ----------------------------------------------------------
# Guards POST /api/v1/tenants and DELETE /api/v1/tenants/:id — the only
# endpoints that operate without a tenant API key. Must be ≥24 characters.
# Generate with: openssl rand -base64 36
ADMIN_API_KEY=

# --- CORS -------------------------------------------------------------------
# Comma-separated allowlist of origins permitted to call the API.
# Leave empty to disable cross-origin requests entirely.
CORS_ORIGINS=http://localhost:3000
