# Secrets for docker-compose.standalone.yml. Copy this file to
# `.env.standalone` and replace every `change-me-*` value. Every placeholder
# below is deliberately invalid against the Zod schema in src/config.ts — if
# the app boots with any of them unchanged, it will fail fast with a clear
# error rather than ship a weak secret.
#
# DATABASE_URL and REDIS_URL are intentionally absent: the compose builds
# them from the POSTGRES_* and REDIS_PASSWORD values below and injects them
# into the app/worker/migrate containers via `environment:`.

# Internal Postgres (inside the docker network; do not change host/port here —
# the compose hard-codes the service DNS name "postgres" and port 5432).
POSTGRES_DB=ksef
POSTGRES_USER=ksef
POSTGRES_PASSWORD=change-me-postgres-password

# Internal Redis (inside the docker network). Use a different value than
# POSTGRES_PASSWORD.
REDIS_PASSWORD=change-me-redis-password

# App
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Envelope-encryption master key — must be base64-encoded 32 raw bytes
# (decodes to exactly 32 bytes). Generate: `openssl rand -base64 32`
ENCRYPTION_KEY=change-me-base64-32-bytes

# Admin API key guarding tenant provisioning endpoints. Must be >= 24 chars;
# the placeholder below is short on purpose so Zod rejects it.
# Generate: `openssl rand -hex 32`
ADMIN_API_KEY=change-me

# Comma-separated list of allowed CORS origins. Leave empty to disable CORS.
CORS_ORIGINS=
