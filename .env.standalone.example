# Internal Postgres (inside the docker network; do not change host/port here —
# the compose hard-codes the service DNS name "postgres" and port 5432).
POSTGRES_DB=ksef
POSTGRES_USER=ksef
POSTGRES_PASSWORD=change-me-strong-password

# Internal Redis (inside the docker network).
REDIS_PASSWORD=change-me-strong-password

# App
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Envelope-encryption master key — must decode to exactly 32 bytes of base64.
# Generate: `openssl rand -base64 32`
ENCRYPTION_KEY=change-me-base64-32-bytes

# Admin API key guarding tenant provisioning endpoints.
# Generate: `openssl rand -hex 32`
ADMIN_API_KEY=change-me-long-random-string

# Comma-separated list of allowed CORS origins. Leave empty to disable CORS.
CORS_ORIGINS=
