{
  "name": "zhr-ksef",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "dev:worker": "tsx watch --env-file=.env src/jobs/worker.ts",
    "build": "tsc && cp -r src/assets dist/",
    "start": "node --env-file=.env dist/index.js",
    "start:worker": "node --env-file=.env dist/jobs/worker.js",
    "db:generate": "node --env-file-if-exists=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "db:studio": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio",
    "test": "node --import tsx --test 'tests/**/*.test.ts'",
    "test:watch": "node --import tsx --test --watch 'tests/**/*.test.ts'"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@react-pdf/renderer": "^4.5.1",
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.74.1",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.6.0",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.11.17",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  }
}
